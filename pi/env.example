# Copy to ~/.config/flustrilo/env and edit.

# Full transcription endpoint. Examples:
#   self-hosted on same machine: http://127.0.0.1:8000/v1/audio/transcriptions
#   self-hosted over Tailscale:  http://<vps-tailscale-ip>:8000/v1/audio/transcriptions
#   OpenAI:                      https://api.openai.com/v1/audio/transcriptions
FLUSTRILO_URL=http://127.0.0.1:8000/v1/audio/transcriptions

# Model name. Must match what the backend serves.
#   speaches/faster-whisper:  Systran/faster-whisper-{tiny,base,small,medium,large-v3,large-v3-turbo}
#   OpenAI:                   whisper-1
FLUSTRILO_MODEL=Systran/faster-whisper-large-v3

# ISO 639-1 language code. Empty string = let Whisper auto-detect.
FLUSTRILO_LANG=

# Bearer token for the backend. Required for OpenAI; usually empty for
# self-hosted servers. Leave the line out (or empty) to skip the header.
#FLUSTRILO_API_KEY=sk-...

# Hard cap on a single recording, seconds. Wrapped via timeout(1) so
# a forgotten session auto-stops.
FLUSTRILO_MAX_SEC=600

# Copy to .env and edit before `docker compose up -d`.

# Network bind. 127.0.0.1 = loopback only (same-machine clients).
# For remote clients, set this to your Tailscale or WireGuard IP, e.g. 100.64.0.0
BIND_ADDR=127.0.0.1
PORT=8000

# Image tag:
#   latest-cpu   — runs anywhere, slower
#   latest-cuda  — NVIDIA GPU; also set WHISPER_COMPUTE_TYPE=float16 below
IMAGE_TAG=latest-cpu

# Model. Any HuggingFace faster-whisper repo:
#   Systran/faster-whisper-tiny
#   Systran/faster-whisper-base
#   Systran/faster-whisper-small         (good Polish/latency tradeoff on CPU)
#   Systran/faster-whisper-medium
#   Systran/faster-whisper-large-v3      (best accuracy; CUDA recommended)
#   Systran/faster-whisper-large-v3-turbo
WHISPER_MODEL=Systran/faster-whisper-small

# Compute type. int8 on CPU, float16 on CUDA.
WHISPER_COMPUTE_TYPE=int8

# Threads when running on CPU. Match physical cores.
WHISPER_CPU_THREADS=4
